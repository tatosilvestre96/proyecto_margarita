# Backend Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/margarita_db

# JWT
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# CORS
FRONTEND_URL=http://localhost:5173

# Socket.io
SOCKET_IO_CORS_ORIGIN=http://localhost:5173

# Email (Opcional - para notificaciones futuras)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Maps (Opcional - para geolocalización futura)
MAPBOX_TOKEN=your_mapbox_token_here

# AWS (Opcional - para storage de imágenes)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=margarita-images

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Session
SESSION_SECRET=your_session_secret_key_here
